{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-symbiote.local/schemas/taskmaster/config.schema.json",
  "title": "Symbiote Taskmaster Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["defaults", "workflow", "execution"],
  "properties": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completionLevel", "defaultPriority", "defaultSubtasks"],
      "properties": {
        "completionLevel": { "type": "integer", "minimum": 1, "maximum": 4 },
        "defaultPriority": { "type": "string", "enum": ["high", "medium", "low"] },
        "defaultSubtasks": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowCrossTagDependencies", "autoLinkPrdStories"],
      "properties": {
        "allowCrossTagDependencies": { "type": "boolean" },
        "autoLinkPrdStories": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plannerRole", "reviewerRole", "qaRole"],
      "properties": {
        "plannerRole": { "type": "string", "minLength": 1 },
        "reviewerRole": { "type": "string", "minLength": 1 },
        "qaRole": { "type": "string", "minLength": 1 }
      }
    }
  }
}
