{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-symbiote.local/schemas/taskmaster/tasks.schema.json",
  "title": "Symbiote Taskmaster Tasks",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tasks"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "status": { "type": "string", "enum": ["pending", "in_progress", "review", "done", "blocked", "deferred", "cancelled"] },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "status", "priority", "dependencies", "details", "testStrategy", "subtasks", "metadata"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "priority": { "$ref": "#/$defs/priority" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "details": { "type": "string" },
        "testStrategy": { "type": "string" },
        "subtasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/subtask" }
        },
        "metadata": { "$ref": "#/$defs/metadata" }
      }
    },
    "subtask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "status", "priority", "dependencies", "details", "testStrategy", "metadata"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "priority": { "$ref": "#/$defs/priority" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "details": { "type": "string" },
        "testStrategy": { "type": "string" },
        "metadata": { "$ref": "#/$defs/metadata" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string", "enum": ["manual", "prd", "agent", "imported"] },
        "tag": { "type": ["string", "null"] },
        "taskFolder": { "type": ["string", "null"] },
        "userStories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "risks": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
